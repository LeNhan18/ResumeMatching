OPENAI_MODEL=openai/gpt-5.2
# Azure OpenAI (nếu dùng thay thế OpenAI)
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=
OPENROUTER_FLUX_MODEL=google/gemini-3.1-flash-image-preview
OPENROUTER_VLM_MODEL=qwen/qwen3-vl-32b-instruct
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

VECTORSTORE_PATH=data/vectorstore
COLLECTION_NAME=cv_matcher

CHUNK_SIZE=4000
CHUNK_OVERLAP=256
TOP_K_RETRIEVAL=5

API_HOST=0.0.0.0
DO_OCR=true
OCR_ENGINE=auto
DO_OCR_POSTPROCESS=true
DO_VLM_TABLE=true
DO_VLM_IMAGE=false

# Redirect AI Models Cache to E drive to save C drive space
HF_HOME=E:\AI_CACHE\huggingface
TORCH_HOME=E:\AI_CACHE\torch
SENTENCE_TRANSFORMERS_HOME=E:\AI_CACHE\sentence_transformers
TRANSFORMERS_CACHE=E:\AI_CACHE\transformers
MODEL_CACHE_DIR=E:\AI_CACHE\surya_models
