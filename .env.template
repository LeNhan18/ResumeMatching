# =====================================================================
# AI CV Matcher Configuration Template
# =====================================================================

# 1. LLM API Configuration (OpenAI, OpenRouter, DeepSeek, or Gemini OpenAI-compatible)
# Fallback is to standard OPENAI_API_KEY. Leave blank to run in MOCK sandbox mode.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_NAME=gpt-4o-mini

# 2. Embedding Configuration
EMBEDDING_MODEL_NAME=text-embedding-3-small
# Set to 'true' to load local BAAI/bge-m3 via sentence-transformers (requires torch & sentence-transformers)
USE_LOCAL_EMBEDDING=false

# 3. Reranker Configuration
# Set to 'true' to load cross-encoder/ms-marco-MiniLM-L-6-v2 locally (requires torch & sentence-transformers)
USE_LOCAL_RERANKER=false

# 4. Vector Database Configuration (Qdrant)
# If QDRANT_URL is left blank, the pipeline will run using a self-contained In-Memory TF-IDF database.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=cv_matcher
